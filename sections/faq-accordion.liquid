{% comment %}
  Section: FAQ Accordion
  Compatible with: Shopify Dawn Theme (v14+)
  Author: John Venedick Natividad
  GitHub: https://github.com/jaynatividad1489

  Dawn conventions used:
  - color_scheme setting
  - page-width container
  - Dawn heading size classes
  - section padding settings
  - Custom Element pattern (details/summary native HTML5)
  - Dawn's icon-caret snippet for the expand icon
  - Accessible: keyboard nav, ARIA, focus-visible
{% endcomment %}

{{ 'section-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="faq color-{{ section.settings.color_scheme }} gradient"
  id="FAQ-{{ section.id }}"
>
  <div class="faq__inner page-width section-{{ section.id }}-padding">

    {%- if section.settings.heading != blank -%}
      <div class="faq__header">
        <h2 class="faq__heading {{ section.settings.heading_size }}">
          {{- section.settings.heading | escape -}}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="faq__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="faq__list" id="FaqList-{{ section.id }}">
        {%- for block in section.blocks -%}
          <details
            class="faq__item"
            id="FaqItem-{{ section.id }}-{{ block.id }}"
            {{ block.shopify_attributes }}
            {% if block.settings.open_by_default %}open{% endif %}
          >
            <summary
              class="faq__question"
              aria-expanded="{{ block.settings.open_by_default }}"
            >
              <span class="faq__question-text">{{ block.settings.question | escape }}</span>
              <span class="faq__icon" aria-hidden="true">
                {%- render 'icon-caret' -%}
              </span>
            </summary>

            <div class="faq__answer">
              <div class="faq__answer-inner rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="faq__cta center">
        <p class="faq__cta-text">
          {{ section.settings.cta_text | escape }}
          {%- if section.settings.cta_label != blank -%}
            <a
              href="{{ section.settings.cta_link }}"
              class="link"
            >
              {{- section.settings.cta_label | escape -}}
            </a>
          {%- endif -%}
        </p>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  class FaqAccordion extends HTMLElement {
    constructor() {
      super();
      this.details = this.querySelectorAll('details.faq__item');
      this.singleOpen = this.dataset.singleOpen === 'true';
      this.init();
    }

    init() {
      this.details.forEach((detail) => {
        const summary = detail.querySelector('summary');
        summary.addEventListener('click', (e) => {
          e.preventDefault();
          this.toggle(detail);
        });

        // Keyboard: Space and Enter already handled by browser on <summary>
        // but we override to control single-open behaviour
        summary.addEventListener('keydown', (e) => {
          if (e.key === ' ' || e.key === 'Enter') {
            e.preventDefault();
            this.toggle(detail);
          }
        });
      });
    }

    toggle(targetDetail) {
      const isOpen = targetDetail.hasAttribute('open');

      if (this.singleOpen && !isOpen) {
        // Close all others
        this.details.forEach((detail) => {
          if (detail !== targetDetail) {
            detail.removeAttribute('open');
            detail.querySelector('summary').setAttribute('aria-expanded', 'false');
          }
        });
      }

      if (isOpen) {
        targetDetail.removeAttribute('open');
        targetDetail.querySelector('summary').setAttribute('aria-expanded', 'false');
      } else {
        targetDetail.setAttribute('open', '');
        targetDetail.querySelector('summary').setAttribute('aria-expanded', 'true');
      }
    }
  }

  customElements.define('faq-accordion', FaqAccordion);

  // Wrap the faq__list in the custom element after DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq__list').forEach((list) => {
      const wrapper = document.createElement('faq-accordion');
      wrapper.dataset.singleOpen = list.closest('.faq')?.dataset.singleOpen || 'true';
      list.parentNode.insertBefore(wrapper, list);
      wrapper.appendChild(list);
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.faq.name",
  "tag": "section",
  "class": "section section-faq",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 20,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.faq.settings.heading.label",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.faq.settings.subheading.label",
      "default": "Got questions? We've got answers."
    },
    {
      "type": "checkbox",
      "id": "single_open",
      "label": "t:sections.faq.settings.single_open.label",
      "default": true,
      "info": "t:sections.faq.settings.single_open.info"
    },
    {
      "type": "header",
      "content": "t:sections.faq.settings.header_cta.content"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.faq.settings.cta_text.label",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.faq.settings.cta_label.label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.faq.settings.cta_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "t:sections.faq.blocks.faq_item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq.blocks.faq_item.settings.question.label",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq.blocks.faq_item.settings.answer.label",
          "default": "<p>We offer a 30-day return policy on all unused items in their original packaging. Contact our support team and we'll guide you through the process.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "t:sections.faq.blocks.faq_item.settings.open_by_default.label",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.presets.name",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What is your return policy?", "answer": "<p>We offer a 30-day return policy on all unused items in their original packaging.</p>" } },
        { "type": "faq_item", "settings": { "question": "How long does shipping take?", "answer": "<p>Standard shipping takes 5–7 business days. Express options are available at checkout.</p>" } },
        { "type": "faq_item", "settings": { "question": "Do you ship internationally?", "answer": "<p>Yes! We ship to over 50 countries worldwide. Shipping rates and times vary by location.</p>" } },
        { "type": "faq_item", "settings": { "question": "How do I track my order?", "answer": "<p>Once your order ships, you'll receive a tracking number via email. Use it on our Track Order page.</p>" } }
      ]
    }
  ]
}
{% endschema %}
