{% comment %}
  Section: Testimonials Slider
  Compatible with: Shopify Dawn Theme (v14+)
  Author: John Venedick Natividad
  GitHub: https://github.com/jaynatividad1489

  Dawn conventions used:
  - color_scheme setting
  - page-width container
  - Dawn's heading size classes (h0, h1, h2)
  - caption-with-letter-spacing utility class
  - Dawn's section padding settings
  - Custom Element pattern (HTMLElement extension)
  - visually-hidden for screen reader text
{% endcomment %}

{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

<div
  class="testimonials color-{{ section.settings.color_scheme }} gradient isolate{% if section.settings.padding_top == 0 %} no-padding-top{% endif %}"
  id="Testimonials-{{ section.id }}"
>
  <div class="testimonials__inner page-width section-{{ section.id }}-padding">

    {%- if section.settings.heading != blank -%}
      <div class="testimonials__header center">
        <h2 class="testimonials__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="testimonials__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <testimonials-slider
        class="testimonials__slider"
        data-autoplay="{{ section.settings.autoplay }}"
        data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
        id="Slider-{{ section.id }}"
        role="region"
        aria-label="{{ 'sections.testimonials.title' | t }}"
      >
        <div class="testimonials__track" id="Track-{{ section.id }}">
          {%- for block in section.blocks -%}
            <div
              class="testimonials__slide{% if forloop.first %} is-active{% endif %}"
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              role="group"
              aria-roledescription="slide"
              aria-label="{{ forloop.index }} of {{ section.blocks.size }}"
              {{ block.shopify_attributes }}
            >
              <blockquote class="testimonials__card">

                {%- comment %} Star Rating {%- endcomment %}
                {%- if block.settings.show_rating -%}
                  <div class="testimonials__rating" aria-label="Rating: {{ block.settings.rating }} out of 5">
                    {%- for i in (1..5) -%}
                      <span
                        class="testimonials__star{% if i <= block.settings.rating %} testimonials__star--active{% endif %}"
                        aria-hidden="true"
                      >
                        {%- render 'icon-star' -%}
                      </span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- comment %} Quote {%- endcomment %}
                {%- if block.settings.quote != blank -%}
                  <p class="testimonials__quote {{ section.settings.quote_size }}">
                    {{ block.settings.quote | escape }}
                  </p>
                {%- endif -%}

                {%- comment %} Author {%- endcomment %}
                <footer class="testimonials__author">
                  {%- if block.settings.author_image != blank -%}
                    <div class="testimonials__author-image media media--circle">
                      {{
                        block.settings.author_image
                        | image_url: width: 80
                        | image_tag:
                          loading: 'lazy',
                          widths: '40, 80',
                          sizes: '40px',
                          alt: block.settings.author_name
                      }}
                    </div>
                  {%- else -%}
                    <div class="testimonials__author-avatar" aria-hidden="true">
                      <span>{{ block.settings.author_name | slice: 0 | upcase }}</span>
                    </div>
                  {%- endif -%}

                  <div class="testimonials__author-details">
                    {%- if block.settings.author_name != blank -%}
                      <cite class="testimonials__author-name">{{ block.settings.author_name | escape }}</cite>
                    {%- endif -%}
                    {%- if block.settings.author_title != blank -%}
                      <span class="testimonials__author-title caption">{{ block.settings.author_title | escape }}</span>
                    {%- endif -%}
                  </div>
                </footer>

              </blockquote>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 1 -%}
          {%- comment %} Prev / Next Buttons {%- endcomment %}
          <div class="testimonials__controls">
            <button
              class="testimonials__btn testimonials__btn--prev button button--secondary"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
              aria-controls="Track-{{ section.id }}"
            >
              {% render 'icon-caret' %}
            </button>
            <button
              class="testimonials__btn testimonials__btn--next button button--secondary"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
              aria-controls="Track-{{ section.id }}"
            >
              {% render 'icon-caret' %}
            </button>
          </div>

          {%- comment %} Dots {%- endcomment %}
          <div class="testimonials__dots" role="tablist" aria-label="{{ 'sections.testimonials.dots_label' | t }}">
            {%- for block in section.blocks -%}
              <button
                class="testimonials__dot{% if forloop.first %} is-active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-label="{{ 'general.slider.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ section.blocks.size }}"
                aria-controls="Slide-{{ section.id }}-{{ forloop.index }}"
                data-index="{{ forloop.index0 }}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </testimonials-slider>
    {%- endif -%}

  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script>
  class TestimonialsSlider extends HTMLElement {
    constructor() {
      super();
      this.track = this.querySelector('.testimonials__track');
      this.slides = this.querySelectorAll('.testimonials__slide');
      this.dots = this.querySelectorAll('.testimonials__dot');
      this.prevBtn = this.querySelector('.testimonials__btn--prev');
      this.nextBtn = this.querySelector('.testimonials__btn--next');
      this.current = 0;
      this.autoplayTimer = null;
      this.autoplay = this.dataset.autoplay === 'true';
      this.speed = parseInt(this.dataset.speed) || 4000;

      this.init();
    }

    init() {
      this.prevBtn?.addEventListener('click', () => { this.goTo(this.current - 1); this.resetAutoplay(); });
      this.nextBtn?.addEventListener('click', () => { this.goTo(this.current + 1); this.resetAutoplay(); });

      this.dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { this.goTo(i); this.resetAutoplay(); });
      });

      // Keyboard support
      this.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft')  { this.goTo(this.current - 1); this.resetAutoplay(); }
        if (e.key === 'ArrowRight') { this.goTo(this.current + 1); this.resetAutoplay(); }
      });

      // Pause autoplay on hover
      this.addEventListener('mouseenter', () => clearInterval(this.autoplayTimer));
      this.addEventListener('mouseleave', () => { if (this.autoplay) this.startAutoplay(); });

      // Touch/swipe support
      this.initSwipe();

      if (this.autoplay) this.startAutoplay();
    }

    goTo(index) {
      const total = this.slides.length;
      const next = ((index % total) + total) % total;

      this.slides[this.current].classList.remove('is-active');
      this.dots[this.current]?.setAttribute('aria-selected', 'false');
      this.dots[this.current]?.classList.remove('is-active');

      this.current = next;

      this.slides[this.current].classList.add('is-active');
      this.dots[this.current]?.setAttribute('aria-selected', 'true');
      this.dots[this.current]?.classList.add('is-active');

      this.track.style.transform = `translateX(-${this.current * 100}%)`;
    }

    startAutoplay() {
      this.autoplayTimer = setInterval(() => this.goTo(this.current + 1), this.speed);
    }

    resetAutoplay() {
      clearInterval(this.autoplayTimer);
      if (this.autoplay) this.startAutoplay();
    }

    initSwipe() {
      let startX = 0;
      this.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
      this.addEventListener('touchend', (e) => {
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          this.goTo(diff > 0 ? this.current + 1 : this.current - 1);
          this.resetAutoplay();
        }
      }, { passive: true });
    }
  }

  customElements.define('testimonials-slider', TestimonialsSlider);
</script>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "section",
  "class": "section section-testimonials",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.settings.heading.label",
      "default": "What Our Customers Say"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.testimonials.settings.subheading.label",
      "default": "Real reviews from real customers"
    },
    {
      "type": "select",
      "id": "quote_size",
      "label": "t:sections.testimonials.settings.quote_size.label",
      "options": [
        { "value": "body",     "label": "t:sections.testimonials.settings.quote_size.options__1.label" },
        { "value": "subtitle", "label": "t:sections.testimonials.settings.quote_size.options__2.label" }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.settings.header_autoplay.content"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.testimonials.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "t:sections.testimonials.settings.autoplay_speed.label",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "t:sections.testimonials.blocks.testimonial.settings.show_rating.label",
          "default": true
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "t:sections.testimonials.blocks.testimonial.settings.rating.label",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.settings.quote.label",
          "default": "This product completely exceeded my expectations. I absolutely love it!"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_image.label"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_name.label",
          "default": "Jane D."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author_title.label",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.presets.name",
      "blocks": [
        { "type": "testimonial", "settings": { "author_name": "Sarah M.", "author_title": "Verified Buyer", "quote": "Absolutely love the quality! Will definitely be ordering again.", "rating": 5 } },
        { "type": "testimonial", "settings": { "author_name": "James R.", "author_title": "Verified Buyer", "quote": "Fast shipping and the product looks even better in person!", "rating": 5 } },
        { "type": "testimonial", "settings": { "author_name": "Priya K.", "author_title": "Verified Buyer", "quote": "Great customer service and a beautiful product. Highly recommend.", "rating": 4 } }
      ]
    }
  ]
}
{% endschema %}
