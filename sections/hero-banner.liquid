{% comment %}
  Section: Hero Banner
  Compatible with: Shopify Dawn Theme (v14+)
  Author: John Venedick Natividad
  GitHub: https://github.com/jaynatividad1489

  Dawn conventions used:
  - color_scheme setting using Dawn's color scheme picker
  - page-width container class
  - Dawn's button classes (.button, .button--primary, .button--secondary)
  - Dawn's animation classes (animate--hover)
  - section-full-width class
  - Lazy loading on images
  - visually-hidden for accessibility
{% endcomment %}

{{ 'section-hero-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #Hero-Banner-{{ section.id }} {
    min-height: {{ section.settings.section_height }}px;
  }
  #Hero-Banner-{{ section.id }} .hero-banner__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<div
  id="Hero-Banner-{{ section.id }}"
  class="hero-banner color-{{ section.settings.color_scheme }} gradient"
>
  {%- if section.settings.image != blank -%}
    <div class="hero-banner__media media">
      {%- assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio -%}
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          class: 'hero-banner__image'
      }}
    </div>
    <div class="hero-banner__overlay"></div>
  {%- endif -%}

  <div class="hero-banner__content page-width hero-banner__content--{{ section.settings.content_alignment }}">
    <div class="hero-banner__box">

      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subheading caption-with-letter-spacing">
          {{- section.settings.subheading | escape -}}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }}
          class="hero-banner__heading {{ section.settings.heading_size }}"
        >
          {{- section.settings.heading | newline_to_br -}}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="hero-banner__text {{ section.settings.text_style }}">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label_1 != blank or section.settings.button_label_2 != blank -%}
        <div class="hero-banner__buttons">
          {%- if section.settings.button_label_1 != blank -%}
            <a
              {% if section.settings.button_link_1 == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ section.settings.button_link_1 }}"
              {% endif %}
              class="button button--primary"
            >
              {{- section.settings.button_label_1 | escape -}}
            </a>
          {%- endif -%}

          {%- if section.settings.button_label_2 != blank -%}
            <a
              {% if section.settings.button_link_2 == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ section.settings.button_link_2 }}"
              {% endif %}
              class="button button--secondary"
            >
              {{- section.settings.button_label_2 | escape -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.hero-banner.name",
  "tag": "section",
  "class": "section section-hero-banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero-banner.settings.image.label"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "t:sections.hero-banner.settings.section_height.label",
      "default": 600
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero-banner.settings.overlay_opacity.label",
      "default": 40
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:sections.hero-banner.settings.content_alignment.label",
      "options": [
        { "value": "left",   "label": "t:sections.all.content_alignment.options__1.label" },
        { "value": "center", "label": "t:sections.all.content_alignment.options__2.label" },
        { "value": "right",  "label": "t:sections.all.content_alignment.options__3.label" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.hero-banner.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.hero-banner.settings.subheading.label",
      "default": "New Collection"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.hero-banner.settings.heading.label",
      "default": "Built for the Bold."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.hero-banner.settings.heading_tag.label",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "p",  "label": "p" }
      ],
      "default": "h2",
      "info": "t:sections.hero-banner.settings.heading_tag.info"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.hero-banner.settings.text.label",
      "default": "<p>Discover our latest collection crafted for those who dare to stand out.</p>"
    },
    {
      "type": "select",
      "id": "text_style",
      "label": "t:sections.hero-banner.settings.text_style.label",
      "options": [
        { "value": "body",    "label": "t:sections.hero-banner.settings.text_style.options__1.label" },
        { "value": "subtitle", "label": "t:sections.hero-banner.settings.text_style.options__2.label" }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "t:sections.hero-banner.settings.header_buttons.content"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "t:sections.hero-banner.settings.button_label_1.label",
      "default": "Shop Now",
      "info": "t:sections.hero-banner.settings.button_label_1.info"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "t:sections.hero-banner.settings.button_link_1.label"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "t:sections.hero-banner.settings.button_label_2.label",
      "default": "Learn More",
      "info": "t:sections.hero-banner.settings.button_label_2.info"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "t:sections.hero-banner.settings.button_link_2.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero-banner.presets.name"
    }
  ]
}
{% endschema %}
